[run]
omit =
    */migrations/*
    */venv/*
    */tests/*
    manage.py
    property_os/wsgi.py
    property_os/asgi.py

[report]
exclude_lines =
    pragma: no cover
    def __repr__
    if self.debug:
    if settings.DEBUG
    raise AssertionError
    raise NotImplementedError
    if 0:
    if __name__ == .__main__.:
