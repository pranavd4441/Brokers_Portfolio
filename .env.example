# -----------------------------------------------------------------------------
# PropertyOS Central Environment Configuration Template
# Copy to .env and customize values for local development or production
# -----------------------------------------------------------------------------

# --- GLOBAL CONFIGS ---
PROJECT_NAME=property-os
ENVIRONMENT=development  # development | staging | production

# --- DATABASE (POSTGRES) ---
# For local development, use DATABASE_URL to point to a local PostgreSQL instance
# This achieves production parity with Render (which also uses PostgreSQL)
#
# Local dev (Windows — postgresql-x64-15 service):
DATABASE_URL=postgres://postgres:<your_local_pg_password>@127.0.0.1:5432/property_os
#
# Docker Compose dev:
# DATABASE_URL=postgres://postgres_admin:secure_postgres_pass_123@db:5432/property_os
#
# Legacy individual variables (used only by Docker Compose services):
POSTGRES_DB=property_os
POSTGRES_USER=postgres_admin
POSTGRES_PASSWORD=secure_postgres_pass_123
POSTGRES_HOST=db
POSTGRES_PORT=5432

# --- CACHE & TASK QUEUE (REDIS) ---
REDIS_URL=redis://redis:6379/0

# --- BACKEND (DJANGO) ---
DJANGO_SECRET_KEY=django-insecure-3x7v*y6h%t_w*u_s^j9w2f1r_l$e6s_d#k@w!o(m%z-l5
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,backend,nginx
DJANGO_CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:80,http://127.0.0.1

# --- SECURITY & AUTH (JWT) ---
JWT_SECRET_KEY=jwt-insecure-super-secret-key-9z#x*c&v_b-n_m$a#s@d!f^g
JWT_ACCESS_TOKEN_LIFETIME_MINUTES=60
JWT_REFRESH_TOKEN_LIFETIME_DAYS=7

# --- OBJECT STORAGE (CLOUDFLARE R2 / AWS S3) ---
# Leave these blank/commented out for local file storage fallback during development
# AWS_ACCESS_KEY_ID=your_r2_or_s3_access_key
# AWS_SECRET_ACCESS_KEY=your_r2_or_s3_secret_key
# AWS_STORAGE_BUCKET_NAME=property-os-media
# AWS_S3_ENDPOINT_URL=https://<account-id>.r2.cloudflarestorage.com

# --- FRONTEND (NEXT.JS) ---
NEXT_PUBLIC_API_URL=http://localhost/api  # Routes through Nginx proxy
NEXT_PUBLIC_SITE_URL=http://localhost
PORT=3000

# --- WHATSAPP GATEWAY CONFIG ---
WHATSAPP_GATEWAY_PROVIDER=MOCK  # MOCK | TWILIO | META
WHATSAPP_VERIFY_TOKEN=propertyos-webhook-verify-token

# TWILIO PROVIDER CREDENTIALS
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886

# META PROVIDER CREDENTIALS
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=

# --- GEMINI AI CONFIG ---
GEMINI_API_KEY=

